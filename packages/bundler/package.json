{
  "name": "@fixerframework/bundler",
  "version": "0.1.0",
  "description": "Shared Vite/Rolldown build CLI and config factories for FixerFramework packages and apps",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fixer-bundle": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite/lib": {
      "types": "./dist/config/vite.lib.d.ts",
      "import": "./dist/vite/lib.js"
    },
    "./vite/app": {
      "types": "./dist/config/vite.app.d.ts",
      "import": "./dist/vite/app.js"
    },
    "./vite/server": {
      "types": "./dist/config/vite.server.d.ts",
      "import": "./dist/vite/server.js"
    },
    "./vitest": {
      "types": "./dist/config/vitest.d.ts",
      "import": "./dist/vitest.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsgo --emitDeclarationOnly -p tsconfig.build.json && bun run ./scripts/rewrite-dts.ts && chmod +x dist/cli.js",
    "check": "bun run ./bin/fixer-bundle.ts --mode lib --no-build --cwd .",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "registry": "https://registry.fixerframework.com",
    "access": "public"
  },
  "dependencies": {
    "@typescript/native-preview": "catalog:typescript",
    "oxfmt": "catalog:binaries",
    "oxlint": "catalog:binaries",
    "rolldown": "catalog:binaries",
    "typescript": "catalog:typescript",
    "vite": "catalog:binaries",
    "vitest": "catalog:binaries"
  },
  "devDependencies": {
    "@oxfmt/binding-linux-x64-gnu": "catalog:bindings",
    "@oxlint/binding-linux-x64-gnu": "catalog:bindings",
    "@rolldown/binding-linux-x64-gnu": "catalog:bindings",
    "@types/bun": "catalog:types",
    "@types/node": "catalog:types",
    "@typescript/native-preview-linux-x64": "catalog:typescript",
    "lightningcss-linux-x64-gnu": "catalog:bindings"
  }
}
