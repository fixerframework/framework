{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "types": []
  },
  "include": ["index.ts", "src/**/*.ts"],
  "exclude": ["test", "dist", "vitest.config.ts", "**/*.test.ts"]
}
