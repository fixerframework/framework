{
  "name": "@fixerframework/auth",
  "version": "0.1.0",
  "description": "Auth runtime for FixerFramework — Clerk client signals bridge and server protect/flow/webhooks",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "fixer-bundle --mode lib --no-format --no-lint --no-typecheck --no-test",
    "check": "fixer-bundle --mode lib --no-build --format-check",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "registry": "https://registry.fixerframework.com",
    "access": "public"
  },
  "dependencies": {
    "@auth/core": "catalog:clerk",
    "@clerk/backend": "catalog:clerk",
    "@clerk/clerk-js": "catalog:clerk",
    "@preact/signals-core": "catalog:preact"
  },
  "devDependencies": {
    "@fixerframework/bundler": "workspace:*",
    "@types/bun": "catalog:types",
    "vitest": "catalog:binaries"
  }
}
